{
  "version": 2,
  "owner": "The User",
  "fallback": {
    "full_repository_read": true,
    "conditions": [
      "outline missing, stale, incomplete, contradictory, or unverified",
      "operation unmapped",
      "tracked file unclassified",
      "inspection map missing or invalid",
      "earlier inspection gate fails"
    ]
  },
  "always_read": [
    "BADASS.md",
    "docs/QUICK-REFERENCE.md",
    "README.md",
    "control/outline.md",
    "control/inspection-map.json",
    "docs/SECTION-COMPLIANCE-MATRIX.md"
  ],
  "groups": {
    "governance": [
      "BADASS.md",
      "README.md",
      "CLAUDE.md",
      "AGENTS.md",
      ".github/copilot-instructions.md",
      "docs/QUICK-REFERENCE.md",
      "docs/INTEGRATION.md",
      "docs/SECTION-COMPLIANCE-MATRIX.md",
      "docs/RECOVERY-PROTOCOL.md",
      "docs/WORKED-EXAMPLE.md"
    ],
    "controls": [
      "control/**"
    ],
    "repository_health": [
      ".gitattributes",
      ".gitignore",
      ".editorconfig",
      ".github/**",
      "CHANGELOG.md",
      "CODE_OF_CONDUCT.md",
      "CONTRIBUTING.md",
      "SECURITY.md",
      "SUPPORT.md",
      "docs/REPOSITORY-HEALTH.md",
      "scripts/**"
    ],
    "decisions": [
      "control/decisions/**",
      "docs/LICENSE-DECISION-GUIDE.md"
    ],
    "culls": [
      "control/culls/**",
      "control/archive/**"
    ],
    "community": [
      "CODE_OF_CONDUCT.md",
      "CONTRIBUTING.md",
      "SECURITY.md",
      "SUPPORT.md",
      ".github/ISSUE_TEMPLATE/**",
      ".github/PULL_REQUEST_TEMPLATE.md",
      ".github/CODEOWNERS"
    ],
    "reviews": [
      "docs/reviews/**"
    ]
  },
  "operations": {
    "session_start": [
      "governance",
      "controls"
    ],
    "assistant_recovery": [
      "governance",
      "controls",
      "decisions"
    ],
    "governance_review": [
      "governance",
      "controls",
      "decisions",
      "reviews"
    ],
    "repository_maintenance": [
      "governance",
      "controls",
      "repository_health",
      "reviews"
    ],
    "cull": [
      "governance",
      "controls",
      "culls",
      "decisions"
    ],
    "contribution_review": [
      "governance",
      "controls",
      "community"
    ],
    "security_review": [
      "governance",
      "controls",
      "repository_health"
    ]
  },
  "classification_patterns": [
    "BADASS.md",
    "README.md",
    "CLAUDE.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "SUPPORT.md",
    ".gitattributes",
    ".gitignore",
    ".editorconfig",
    ".github/**",
    "docs/**",
    "control/**",
    "scripts/**"
  ]
}
