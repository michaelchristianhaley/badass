{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelchristianhaley/badass/schemas/state.schema.json",
  "title": "BADASS structured repository state",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "project",
    "branch",
    "status",
    "updated",
    "current_end_goal",
    "active_operation",
    "next_goal",
    "authoritative_paths",
    "license_status",
    "open_user_decisions",
    "required_checks"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "../schemas/state.schema.json"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "string",
      "const": "BADASS"
    },
    "branch": {
      "type": "string",
      "const": "main"
    },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "blocked", "complete"]
    },
    "updated": {
      "type": "string",
      "pattern": "\\d{4}-\\d{2}-\\d{2}"
    },
    "current_end_goal": {
      "type": "string",
      "minLength": 1
    },
    "active_operation": {
      "type": "object",
      "required": [
        "id",
        "name",
        "status",
        "inspected_base_commit",
        "resulting_commit"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["planned", "in_progress", "blocked", "complete"]
        },
        "inspected_base_commit": {
          "type": "string",
          "pattern": "[0-9a-f]{40}"
        },
        "resulting_commit": {
          "type": "string",
          "const": "self"
        }
      }
    },
    "next_goal": {
      "type": "string",
      "minLength": 1
    },
    "authoritative_paths": {
      "type": "object",
      "required": ["constitution", "outline", "inspection_map", "state"],
      "additionalProperties": false,
      "properties": {
        "constitution": {
          "type": "string",
          "const": "BADASS.md"
        },
        "outline": {
          "type": "string",
          "const": "control/outline.md"
        },
        "inspection_map": {
          "type": "string",
          "const": "control/inspection-map.json"
        },
        "state": {
          "type": "string",
          "const": "control/state.json"
        }
      }
    },
    "license_status": {
      "type": "string",
      "enum": ["unresolved", "selected"]
    },
    "open_user_decisions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_checks": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["validate", "state-sync"]
      }
    }
  }
}
